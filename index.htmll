<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Minhas Finanças PRO - ASM</title>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jspdf/2.5.1/jspdf.umd.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/js/all.min.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.22.0/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.22.0/firebase-auth-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/9.22.0/firebase-database-compat.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;600;700&family=Inter:wght@300;400;500;600&display=swap" rel="stylesheet">
    <style>
        :root {
            --navy: #1a237e;
            --navy-light: #283593;
            --navy-dark: #0d1642;
            --gold: #d4af37;
            --gold-light: #f4d03f;
            --gold-dark: #b8860b;
            --white: #ffffff;
            --gray-light: #f5f5f5;
            --gray: #9e9e9e;
            --success: #4caf50;
            --danger: #f44336;
            --warning: #ff9800;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Inter', sans-serif;
            background: linear-gradient(135deg, var(--navy-dark) 0%, var(--navy) 100%);
            min-height: 100vh;
            color: var(--navy-dark);
        }

        .app-container {
            max-width: 480px;
            margin: 0 auto;
            background: var(--gray-light);
            min-height: 100vh;
            position: relative;
            box-shadow: 0 0 50px rgba(0,0,0,0.3);
        }

        /* TELA DE ATIVAÇÃO */
        .activation-screen {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(135deg, var(--navy-dark) 0%, var(--navy) 100%);
            z-index: 6000;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }

        .activation-logo {
            text-align: center;
            margin-bottom: 30px;
        }

        .activation-logo i {
            font-size: 64px;
            color: var(--gold);
            margin-bottom: 20px;
        }

        .activation-logo h1 {
            font-family: 'Playfair Display', serif;
            color: var(--white);
            font-size: 28px;
            margin-bottom: 10px;
        }

        .activation-box {
            width: 100%;
            max-width: 360px;
            background: rgba(255,255,255,0.1);
            backdrop-filter: blur(10px);
            padding: 30px;
            border-radius: 20px;
            border: 1px solid rgba(212,175,55,0.3);
        }

        .activation-title {
            color: var(--gold);
            font-size: 18px;
            font-weight: 600;
            margin-bottom: 20px;
            text-align: center;
        }

        .activation-input {
            width: 100%;
            padding: 16px;
            margin-bottom: 15px;
            border: 2px solid rgba(212,175,55,0.5);
            border-radius: 12px;
            background: rgba(255,255,255,0.1);
            color: var(--white);
            font-size: 16px;
        }

        .activation-input::placeholder {
            color: rgba(255,255,255,0.5);
        }

        .activation-btn {
            width: 100%;
            padding: 16px;
            background: linear-gradient(135deg, var(--gold) 0%, var(--gold-dark) 100%);
            color: var(--navy-dark);
            border: none;
            border-radius: 12px;
            font-size: 16px;
            font-weight: 700;
            cursor: pointer;
            margin-top: 10px;
        }

        .activation-btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

        .activation-error {
            color: var(--danger);
            font-size: 14px;
            text-align: center;
            margin-top: 10px;
            display: none;
            background: rgba(244,67,54,0.2);
            padding: 10px;
            border-radius: 8px;
        }

        .activation-success {
            color: var(--success);
            font-size: 14px;
            text-align: center;
            margin-top: 10px;
            display: none;
            background: rgba(76,175,80,0.2);
            padding: 10px;
            border-radius: 8px;
        }

        /* AUTH SCREEN */
        .auth-screen {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: linear-gradient(135deg, var(--navy-dark) 0%, var(--navy) 100%);
            z-index: 5000;
            display: none;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }

        .auth-logo {
            text-align: center;
            margin-bottom: 40px;
        }

        .auth-logo i {
            font-size: 64px;
            color: var(--gold);
            margin-bottom: 20px;
        }

        .auth-logo h1 {
            font-family: 'Playfair Display', serif;
            color: var(--white);
            font-size: 32px;
            margin-bottom: 10px;
        }

        .auth-logo p {
            color: var(--gold-light);
            font-size: 14px;
        }

        .auth-form {
            width: 100%;
            max-width: 360px;
            background: rgba(255,255,255,0.1);
            backdrop-filter: blur(10px);
            padding: 30px;
            border-radius: 20px;
            border: 1px solid rgba(212,175,55,0.3);
        }

        .auth-tabs {
            display: flex;
            margin-bottom: 20px;
            background: rgba(0,0,0,0.2);
            border-radius: 12px;
            padding: 4px;
        }

        .auth-tab {
            flex: 1;
            padding: 12px;
            text-align: center;
            color: var(--white);
            cursor: pointer;
            border-radius: 8px;
            transition: all 0.3s;
            font-size: 14px;
            font-weight: 500;
        }

        .auth-tab.active {
            background: var(--gold);
            color: var(--navy-dark);
        }

        .auth-input {
            width: 100%;
            padding: 14px;
            margin-bottom: 15px;
            border: 2px solid rgba(255,255,255,0.2);
            border-radius: 12px;
            background: rgba(255,255,255,0.1);
            color: var(--white);
            font-size: 16px;
        }

        .auth-input::placeholder {
            color: rgba(255,255,255,0.5);
        }

        .auth-btn {
            width: 100%;
            padding: 16px;
            background: linear-gradient(135deg, var(--gold) 0%, var(--gold-dark) 100%);
            color: var(--navy-dark);
            border: none;
            border-radius: 12px;
            font-size: 16px;
            font-weight: 700;
            cursor: pointer;
            margin-top: 10px;
        }

        .auth-divider {
            text-align: center;
            margin: 20px 0;
            color: rgba(255,255,255,0.5);
            font-size: 12px;
        }

        .google-btn {
            width: 100%;
            padding: 14px;
            background: var(--white);
            color: var(--navy-dark);
            border: none;
            border-radius: 12px;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 10px;
        }

        /* HEADER */
        .header {
            background: linear-gradient(135deg, var(--navy) 0%, var(--navy-dark) 100%);
            padding: 20px;
            color: var(--white);
            position: relative;
            overflow: hidden;
        }

        .header-top {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 15px;
        }

        .header-title {
            font-family: 'Playfair Display', serif;
            font-size: 24px;
            font-weight: 600;
        }

        .header-actions {
            display: flex;
            gap: 10px;
        }

        .header-btn {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            background: rgba(255,255,255,0.1);
            border: none;
            color: var(--gold);
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .month-selector {
            background: var(--white);
            padding: 15px 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .month-display {
            font-size: 18px;
            font-weight: 600;
            color: var(--navy);
        }

        .month-btn {
            background: var(--navy);
            color: var(--gold);
            border: none;
            width: 36px;
            height: 36px;
            border-radius: 50%;
            cursor: pointer;
            margin-left: 10px;
        }

        /* CARDS */
        .summary-cards {
            padding: 20px;
            display: grid;
            gap: 15px;
        }

        .card {
            background: var(--white);
            border-radius: 16px;
            padding: 20px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.08);
        }

        .card-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 10px;
        }

        .card-label {
            font-size: 12px;
            text-transform: uppercase;
            letter-spacing: 1px;
            color: var(--gray);
            font-weight: 600;
        }

        .card-icon {
            width: 40px;
            height: 40px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
        }

        .card-icon.income {
            background: rgba(76,175,80,0.1);
            color: var(--success);
        }

        .card-icon.expense {
            background: rgba(244,67,54,0.1);
            color: var(--danger);
        }

        .card-icon.balance {
            background: rgba(26,35,126,0.1);
            color: var(--navy);
        }

        .card-value {
            font-size: 28px;
            font-weight: 700;
            color: var(--navy-dark);
            margin-bottom: 5px;
        }

        .card-value.positive {
            color: var(--success);
        }

        .card-value.negative {
            color: var(--danger);
        }

        .alert-box {
            margin: 0 20px 20px;
            padding: 15px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            gap: 12px;
        }

        .alert-box.warning {
            background: linear-gradient(135deg, #fff8e1 0%, #ffecb3 100%);
            border-left: 4px solid var(--gold);
        }

        .alert-box.success {
            background: linear-gradient(135deg, #e8f5e9 0%, #c8e6c9 100%);
            border-left: 4px solid var(--success);
        }

        .alert-box.danger {
            background: linear-gradient(135deg, #ffebee 0%, #ffcdd2 100%);
            border-left: 4px solid var(--danger);
        }

        .quick-actions {
            padding: 0 20px 20px;
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
        }

        .action-btn {
            background: linear-gradient(135deg, var(--navy) 0%, var(--navy-light) 100%);
            color: var(--white);
            border: none;
            padding: 16px;
            border-radius: 12px;
            cursor: pointer;
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 8px;
        }

        .action-btn i {
            font-size: 24px;
            color: var(--gold);
        }

        .section-title {
            padding: 20px 20px 10px;
            font-size: 14px;
            font-weight: 600;
            color: var(--navy);
            text-transform: uppercase;
            letter-spacing: 1px;
            display: flex;
            align-items: center;
            gap: 8px;
        }

        /* TRANSACTIONS */
        .transactions {
            padding: 0 20px 100px;
        }

        .transaction-item {
            background: var(--white);
            border-radius: 12px;
            padding: 15px;
            margin-bottom: 10px;
            display: flex;
            align-items: center;
            gap: 12px;
            box-shadow: 0 2px 8px rgba(0,0,0,0.05);
            position: relative;
        }

        .transaction-icon {
            width: 45px;
            height: 45px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 18px;
        }

        .transaction-icon.income {
            background: rgba(76,175,80,0.1);
            color: var(--success);
        }

        .transaction-icon.expense {
            background: rgba(244,67,54,0.1);
            color: var(--danger);
        }

        .transaction-info {
            flex: 1;
        }

        .transaction-title {
            font-weight: 600;
            font-size: 14px;
            color: var(--navy-dark);
        }

        .transaction-category {
            font-size: 11px;
            color: var(--gray);
            display: flex;
            align-items: center;
            gap: 5px;
        }

        .category-dot {
            width: 8px;
            height: 8px;
            border-radius: 50%;
        }

        .transaction-amount {
            font-weight: 700;
            font-size: 16px;
        }

        .transaction-amount.income {
            color: var(--success);
        }

        .transaction-amount.expense {
            color: var(--danger);
        }

        /* BOTTOM NAV */
        .bottom-nav {
            position: fixed;
            bottom: 0;
            left: 50%;
            transform: translateX(-50%);
            width: 100%;
            max-width: 480px;
            background: var(--white);
            display: flex;
            justify-content: space-around;
            padding: 12px 0;
            box-shadow: 0 -4px 20px rgba(0,0,0,0.1);
            z-index: 1000;
            border-top: 2px solid var(--gold);
        }

        .nav-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 4px;
            cursor: pointer;
            padding: 5px 15px;
            border-radius: 12px;
        }

        .nav-item.active i {
            color: var(--gold);
        }

        .nav-item i {
            font-size: 20px;
            color: var(--gray);
        }

        .nav-item span {
            font-size: 10px;
            color: var(--gray);
        }

        /* MODALS */
        .modal {
            display: none;
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background: rgba(0,0,0,0.5);
            z-index: 2000;
            justify-content: center;
            align-items: flex-end;
        }

        .modal.active {
            display: flex;
        }

        .modal-content {
            background: var(--white);
            width: 100%;
            max-width: 480px;
            border-radius: 24px 24px 0 0;
            padding: 25px;
            max-height: 90vh;
            overflow-y: auto;
        }

        .modal-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 20px;
        }

        .modal-title {
            font-family: 'Playfair Display', serif;
            font-size: 22px;
            color: var(--navy);
        }

        .modal-close {
            background: none;
            border: none;
            font-size: 24px;
            color: var(--gray);
            cursor: pointer;
            width: 40px;
            height: 40px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .form-group {
            margin-bottom: 20px;
        }

        .form-label {
            display: block;
            font-size: 12px;
            font-weight: 600;
            color: var(--navy);
            margin-bottom: 8px;
            text-transform: uppercase;
        }

        .form-input, .form-select {
            width: 100%;
            padding: 14px;
            border: 2px solid #e0e0e0;
            border-radius: 12px;
            font-size: 16px;
            font-family: 'Inter', sans-serif;
        }

        .type-selector {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px;
            margin-bottom: 20px;
        }

        .type-option {
            padding: 15px;
            border: 2px solid #e0e0e0;
            border-radius: 12px;
            text-align: center;
            cursor: pointer;
        }

        .type-option.selected.income {
            border-color: var(--success);
            background: rgba(76,175,80,0.1);
        }

        .type-option.selected.expense {
            border-color: var(--danger);
            background: rgba(244,67,54,0.1);
        }

        .type-option i {
            font-size: 24px;
            margin-bottom: 5px;
            display: block;
        }

        .btn-primary {
            width: 100%;
            padding: 16px;
            background: linear-gradient(135deg, var(--navy) 0%, var(--navy-light) 100%);
            color: var(--white);
            border: none;
            border-radius: 12px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
        }

        .btn-secondary {
            width: 100%;
            padding: 14px;
            background: transparent;
            color: var(--navy);
            border: 2px solid var(--navy);
            border-radius: 12px;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            margin-top: 10px;
        }

        /* SECTIONS */
        .section {
            display: none;
        }

        .section.active {
            display: block;
        }

        /* REPORTS - LAYOUT FIXO */
        .reports-container {
            padding: 20px;
            display: flex;
            flex-direction: column;
            gap: 20px;
        }

        .chart-container {
            background: var(--white);
            border-radius: 16px;
            padding: 20px;
            box-shadow: 0 4px 15px rgba(0,0,0,0.08);
            position: relative;
            height: 300px;
        }

        .chart-title {
            font-size: 16px;
            font-weight: 600;
            color: var(--navy);
            margin-bottom: 15px;
        }

        .pdf-btn {
            position: fixed;
            bottom: 90px;
            right: 20px;
            width: 56px;
            height: 56px;
            border-radius: 50%;
            background: linear-gradient(135deg, var(--gold) 0%, var(--gold-dark) 100%);
            color: var(--navy-dark);
            border: none;
            font-size: 24px;
            cursor: pointer;
            box-shadow: 0 4px 15px rgba(212,175,55,0.4);
            z-index: 100;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        /* CATEGORY MANAGEMENT */
        .category-list {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 10px;
            margin-bottom: 20px;
        }

        .category-item {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 10px;
            background: var(--gray-light);
            border-radius: 10px;
            font-size: 13px;
        }

        .color-picker {
            display: flex;
            gap: 10px;
            flex-wrap: wrap;
            margin-top: 10px;
        }

        .color-option {
            width: 30px;
            height: 30px;
            border-radius: 50%;
            cursor: pointer;
            border: 3px solid transparent;
        }

        .color-option.selected {
            border-color: var(--navy);
        }

        .empty-state {
            text-align: center;
            padding: 40px 20px;
            color: var(--gray);
        }

        .empty-state i {
            font-size: 48px;
            margin-bottom: 15px;
            color: var(--gold);
            opacity: 0.5;
        }

        .sync-indicator {
            position: fixed;
            top: 20px;
            right: 20px;
            background: var(--success);
            color: white;
            padding: 8px 15px;
            border-radius: 20px;
            font-size: 12px;
            font-weight: 600;
            z-index: 4000;
            opacity: 0;
            transition: opacity 0.3s;
        }

        .sync-indicator.show {
            opacity: 1;
        }

        .loading-spinner {
            display: inline-block;
            width: 20px;
            height: 20px;
            border: 3px solid rgba(255,255,255,.3);
            border-radius: 50%;
            border-top-color: var(--gold);
            animation: spin 1s ease-in-out infinite;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }
    </style>
</head>
<body>
    <div class="sync-indicator" id="syncIndicator">
        <i class="fas fa-check-circle"></i> Sincronizado
    </div>

    <!-- TELA DE ATIVAÇÃO -->
    <div class="activation-screen" id="activationScreen">
        <div class="activation-logo">
            <i class="fas fa-wallet"></i>
            <h1>Minhas Finanças PRO</h1>
            <p>ASM Gestão Financeira</p>
        </div>
        <div class="activation-box">
            <div class="activation-title">🔐 Ativação do Sistema</div>
            <p style="color: rgba(255,255,255,0.7); font-size: 13px; margin-bottom: 20px; text-align: center;">
                Complete seus dados para ativar o sistema
            </p>
            
            <input type="text" class="activation-input" id="actName" placeholder="Nome completo">
            <input type="email" class="activation-input" id="actEmail" placeholder="E-mail">
            <input type="text" class="activation-input" id="actCPF" placeholder="CPF" maxlength="14" oninput="formatCPF(this)">
            <input type="text" class="activation-input" id="actWhatsApp" placeholder="WhatsApp" maxlength="15" oninput="formatWhatsApp(this)">
            <input type="text" class="activation-input" id="actCode" placeholder="Código de ativação (RVR#####)" maxlength="8" style="text-transform: uppercase;">
            
            <button class="activation-btn" id="activateBtn" onclick="activateSystem()">
                <span>ATIVAR SISTEMA</span>
            </button>
            
            <div class="activation-error" id="activationError"></div>
            <div class="activation-success" id="activationSuccess"></div>
        </div>
    </div>

    <!-- Auth Screen -->
    <div class="auth-screen" id="authScreen">
        <div class="auth-logo">
            <i class="fas fa-wallet"></i>
            <h1>Minhas Finanças PRO</h1>
            <p>Gestão Financeira Inteligente</p>
        </div>
        <div class="auth-form">
            <div class="auth-tabs">
                <div class="auth-tab active" onclick="switchAuthTab('login')">Entrar</div>
                <div class="auth-tab" onclick="switchAuthTab('register')">Criar Conta</div>
            </div>
            <div id="loginForm">
                <input type="email" class="auth-input" id="loginEmail" placeholder="E-mail">
                <input type="password" class="auth-input" id="loginPassword" placeholder="Senha">
                <button class="auth-btn" onclick="login()">Entrar</button>
            </div>
            <div id="registerForm" style="display: none;">
                <input type="text" class="auth-input" id="registerName" placeholder="Nome completo">
                <input type="email" class="auth-input" id="registerEmail" placeholder="E-mail">
                <input type="password" class="auth-input" id="registerPassword" placeholder="Senha">
                <button class="auth-btn" onclick="register()">Criar Conta</button>
            </div>
            <div class="auth-divider">ou</div>
            <button class="google-btn" onclick="loginWithGoogle()">
                <i class="fab fa-google"></i> Continuar com Google
            </button>
        </div>
    </div>

    <!-- Main App -->
    <div class="app-container" id="mainApp" style="display: none;">
        <div class="header">
            <div class="header-top">
                <div class="header-title">Minhas Finanças</div>
                <div class="header-actions">
                    <button class="header-btn" onclick="syncData()" title="Sincronizar">
                        <i class="fas fa-sync-alt"></i>
                    </button>
                    <button class="header-btn" onclick="logout()" title="Sair">
                        <i class="fas fa-sign-out-alt"></i>
                    </button>
                </div>
            </div>
        </div>

        <div class="month-selector">
            <div class="month-display" id="currentMonth">Março 2026</div>
            <div>
                <button class="month-btn" onclick="changeMonth(-1)"><i class="fas fa-chevron-left"></i></button>
                <button class="month-btn" onclick="changeMonth(1)"><i class="fas fa-chevron-right"></i></button>
            </div>
        </div>

        <!-- Dashboard -->
        <div id="dashboardSection" class="section active">
            <div class="summary-cards">
                <div class="card">
                    <div class="card-header">
                        <span class="card-label">Entradas</span>
                        <div class="card-icon income"><i class="fas fa-arrow-down"></i></div>
                    </div>
                    <div class="card-value positive" id="totalIncome">R$ 0,00</div>
                </div>
                <div class="card">
                    <div class="card-header">
                        <span class="card-label">Saídas</span>
                        <div class="card-icon expense"><i class="fas fa-arrow-up"></i></div>
                    </div>
                    <div class="card-value negative" id="totalExpense">R$ 0,00</div>
                </div>
                <div class="card">
                    <div class="card-header">
                        <span class="card-label">Saldo</span>
                        <div class="card-icon balance"><i class="fas fa-wallet"></i></div>
                    </div>
                    <div class="card-value" id="totalBalance">R$ 0,00</div>
                </div>
            </div>

            <div id="alertBox" class="alert-box warning">
                <div class="alert-icon">⚠️</div>
                <div>
                    <div style="font-weight: 600;" id="alertTitle">Atenção!</div>
                    <div style="font-size: 11px; color: var(--gray);" id="alertText">Você já gastou 90% da renda</div>
                </div>
            </div>

            <div class="quick-actions">
                <button class="action-btn" onclick="openModal('income')">
                    <i class="fas fa-plus-circle"></i>
                    <span>Nova Entrada</span>
                </button>
                <button class="action-btn" onclick="openModal('expense')">
                    <i class="fas fa-minus-circle"></i>
                    <span>Nova Saída</span>
                </button>
            </div>

            <div class="section-title">
                <i class="fas fa-list"></i> Lançamentos Recentes
            </div>
            <div class="transactions" id="recentTransactions">
                <div class="empty-state">
                    <i class="fas fa-receipt"></i>
                    <p>Nenhum lançamento</p>
                </div>
            </div>
        </div>

        <!-- Reports - LAYOUT FIXO -->
        <div id="reportsSection" class="section">
            <div class="reports-container">
                <div class="chart-container">
                    <div class="chart-title">Gastos por Categoria</div>
                    <canvas id="expenseChart"></canvas>
                </div>
                <div class="chart-container">
                    <div class="chart-title">Evolução Mensal</div>
                    <canvas id="trendChart"></canvas>
                </div>
            </div>
        </div>

        <!-- Categories -->
        <div id="categoriesSection" class="section">
            <div class="section-title">
                <i class="fas fa-tags"></i> Categorias
            </div>
            <div style="padding: 0 20px;">
                <div class="category-list" id="categoryList"></div>
                <button class="btn-primary" onclick="openCategoryModal()" style="margin-bottom: 100px;">
                    <i class="fas fa-plus"></i> Nova Categoria
                </button>
            </div>
        </div>

        <!-- All Transactions -->
        <div id="allTransactionsSection" class="section">
            <div class="section-title">
                <i class="fas fa-list-alt"></i> Todos os Lançamentos
            </div>
            <div class="transactions" id="allTransactions" style="padding-top: 20px;"></div>
        </div>

        <!-- Bottom Nav -->
        <div class="bottom-nav">
            <div class="nav-item active" onclick="showSection('dashboard')">
                <i class="fas fa-home"></i>
                <span>Início</span>
            </div>
            <div class="nav-item" onclick="showSection('allTransactions')">
                <i class="fas fa-list"></i>
                <span>Lançamentos</span>
            </div>
            <div class="nav-item" onclick="showSection('categories')">
                <i class="fas fa-tags"></i>
                <span>Categorias</span>
            </div>
            <div class="nav-item" onclick="showSection('reports')">
                <i class="fas fa-chart-pie"></i>
                <span>Relatórios</span>
            </div>
        </div>

        <button class="pdf-btn" onclick="generatePDF()" title="Gerar PDF">
            <i class="fas fa-file-pdf"></i>
        </button>
    </div>

    <!-- Transaction Modal -->
    <div class="modal" id="transactionModal">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title">Novo Lançamento</h2>
                <button class="modal-close" onclick="closeModal()">&times;</button>
            </div>
            <div class="type-selector">
                <div class="type-option income" onclick="selectType('income')">
                    <i class="fas fa-arrow-down"></i>
                    <span>Entrada</span>
                </div>
                <div class="type-option expense" onclick="selectType('expense')">
                    <i class="fas fa-arrow-up"></i>
                    <span>Saída</span>
                </div>
            </div>
            <form onsubmit="saveTransaction(event)">
                <div class="form-group">
                    <label class="form-label">Valor</label>
                    <input type="text" class="form-input" id="amount" placeholder="R$ 0,00" oninput="formatCurrency(this)" required>
                </div>
                <div class="form-group">
                    <label class="form-label">Data</label>
                    <input type="date" class="form-input" id="date" required>
                </div>
                <div class="form-group">
                    <label class="form-label">Categoria</label>
                    <select class="form-select" id="category" required></select>
                </div>
                <div class="form-group">
                    <label class="form-label">Descrição (opcional)</label>
                    <input type="text" class="form-input" id="description" placeholder="Ex: Supermercado Extra">
                </div>
                <button type="submit" class="btn-primary">Salvar</button>
                <button type="button" class="btn-secondary" onclick="closeModal()">Cancelar</button>
            </form>
        </div>
    </div>

    <!-- Category Modal -->
    <div class="modal" id="categoryModal">
        <div class="modal-content">
            <div class="modal-header">
                <h2 class="modal-title">Nova Categoria</h2>
                <button class="modal-close" onclick="closeCategoryModal()">&times;</button>
            </div>
            <form onsubmit="saveCategory(event)">
                <div class="form-group">
                    <label class="form-label">Nome da Categoria</label>
                    <input type="text" class="form-input" id="newCategoryName" placeholder="Ex: Academia" required>
                </div>
                <div class="form-group">
                    <label class="form-label">Cor</label>
                    <div class="color-picker" id="colorPicker"></div>
                </div>
                <button type="submit" class="btn-primary">Criar Categoria</button>
                <button type="button" class="btn-secondary" onclick="closeCategoryModal()">Cancelar</button>
            </form>
        </div>
    </div>

    <script>
        // ============================================
        // FIREBASE CONFIG - asm-financeiro-pro
        // ============================================
        const firebaseConfig = {
            apiKey: "AIzaSyCcVS9BVbZjogyUQ9vvYExPNqyDwKy9TcQ",
            authDomain: "asm-financeiro-pro.firebaseapp.com",
            databaseURL: "https://asm-financeiro-pro-default-rtdb.firebaseio.com",
            projectId: "asm-financeiro-pro",
            storageBucket: "asm-financeiro-pro.firebasestorage.app",
            messagingSenderId: "209611478144",
            appId: "1:209611478144:web:ad61d87cf7d6500f56c265"
        };

        let app, auth, database;
        let currentUser = null;
        let isOnline = false;
        let isActivated = localStorage.getItem('systemActivated') === 'true';

        // Dados locais
        let transactions = JSON.parse(localStorage.getItem('transactions')) || [];
        let customCategories = JSON.parse(localStorage.getItem('customCategories')) || [];
        let currentDate = new Date();
        let currentType = 'expense';
        let selectedColor = '#ef4444';

        // Categorias pré-definidas expandidas
        const defaultCategories = {
            income: {
                'Salário': '#22c55e',
                'Investimentos': '#10b981',
                'Freelance': '#14b8a6',
                'Presente': '#06b6d4',
                'Reembolso': '#0ea5e9',
                'Outros': '#64748b'
            },
            expense: {
                'Moradia': '#ef4444',
                'Aluguel': '#dc2626',
                'Condomínio': '#b91c1c',
                'IPTU': '#991b1b',
                'Alimentação': '#f97316',
                'Supermercado': '#ea580c',
                'Restaurante': '#c2410c',
                'Delivery': '#9a3412',
                'Transporte': '#eab308',
                'Combustível': '#ca8a04',
                'Uber/99': '#a16207',
                'Financiamento Carro': '#854d0e',
                'Parcela Carro': '#713f12',
                'Seguro Carro': '#fcd34d',
                'Manutenção Carro': '#fbbf24',
                'Saúde': '#22c55e',
                'Plano de Saúde': '#16a34a',
                'Farmácia': '#15803d',
                'Consultas': '#166534',
                'Exames': '#14532d',
                'Educação': '#3b82f6',
                'Cursos': '#2563eb',
                'Livros': '#1d4ed8',
                'Material Escolar': '#1e40af',
                'Lazer': '#8b5cf6',
                'Cinema': '#7c3aed',
                'Viagem': '#6d28d9',
                'Hobbies': '#5b21b6',
                'Assinaturas': '#4c1d95',
                'Beleza': '#ec4899',
                'Salão': '#db2777',
                'Cosméticos': '#be185d',
                'Roupas': '#9d174d',
                'Academia': '#831843',
                'Contas': '#06b6d4',
                'Luz': '#0891b2',
                'Água': '#0e7490',
                'Internet': '#155e75',
                'Celular': '#164e63',
                'Cartão': '#f43f5e',
                'Fatura': '#e11d48',
                'Parcelas': '#be123c',
                'Juros': '#9f1239',
                'Outros': '#6b7280'
            }
        };

        const availableColors = [
            '#ef4444', '#f97316', '#eab308', '#22c55e', '#10b981',
            '#06b6d4', '#3b82f6', '#6366f1', '#8b5cf6', '#a855f7',
            '#ec4899', '#f43f5e', '#78716c', '#dc2626', '#84cc16'
        ];

        // Inicialização
        document.addEventListener('DOMContentLoaded', function() {
            try {
                if (typeof firebase !== 'undefined') {
                    app = firebase.initializeApp(firebaseConfig);
                    auth = firebase.auth();
                    database = firebase.database();
                    isOnline = true;
                    
                    auth.onAuthStateChanged(user => {
                        if (user && isActivated) {
                            currentUser = user;
                            loadUserData();
                            showMainApp();
                        } else if (!isActivated) {
                            showActivationScreen();
                        } else {
                            showAuthScreen();
                        }
                    });
                } else {
                    if (isActivated) {
                        showAuthScreen();
                    } else {
                        showActivationScreen();
                    }
                }
            } catch (e) {
                console.log('Firebase não configurado');
                if (isActivated) {
                    showAuthScreen();
                } else {
                    showActivationScreen();
                }
            }
            
            updateMonthDisplay();
            loadTransactions();
            renderCategories();
            initColorPicker();
            document.getElementById('date').valueAsDate = new Date();
        });

        // ============================================
        // ATIVAÇÃO DO SISTEMA - CONSULTA FIREBASE
        // ============================================
        function showActivationScreen() {
            document.getElementById('activationScreen').style.display = 'flex';
            document.getElementById('authScreen').style.display = 'none';
            document.getElementById('mainApp').style.display = 'none';
        }

        function formatCPF(input) {
            let value = input.value.replace(/\D/g, '');
            value = value.replace(/(\d{3})(\d)/, '$1.$2');
            value = value.replace(/(\d{3})(\d)/, '$1.$2');
            value = value.replace(/(\d{3})(\d{1,2})$/, '$1-$2');
            input.value = value;
        }

        function formatWhatsApp(input) {
            let value = input.value.replace(/\D/g, '');
            if (value.length <= 2) {
                input.value = value;
            } else if (value.length <= 7) {
                input.value = `(${value.slice(0, 2)}) ${value.slice(2)}`;
            } else {
                input.value = `(${value.slice(0, 2)}) ${value.slice(2, 7)}-${value.slice(7, 11)}`;
            }
        }

        async function activateSystem() {
            const name = document.getElementById('actName').value.trim();
            const email = document.getElementById('actEmail').value.trim();
            const cpf = document.getElementById('actCPF').value.trim();
            const whatsapp = document.getElementById('actWhatsApp').value.trim();
            const code = document.getElementById('actCode').value.toUpperCase().trim();
            
            const errorDiv = document.getElementById('activationError');
            const successDiv = document.getElementById('activationSuccess');
            const btn = document.getElementById('activateBtn');
            
            errorDiv.style.display = 'none';
            successDiv.style.display = 'none';
            
            // Validações
            if (!name || !email || !cpf || !whatsapp || !code) {
                errorDiv.textContent = 'Preencha todos os campos';
                errorDiv.style.display = 'block';
                return;
            }
            
            if (!code.match(/^RVR\d{5}$/)) {
                errorDiv.textContent = 'Formato inválido. Use: RVR + 5 números (ex: RVR12345)';
                errorDiv.style.display = 'block';
                return;
            }
            
            if (!isOnline || !database) {
                errorDiv.textContent = 'Sem conexão com o servidor. Tente novamente.';
                errorDiv.style.display = 'block';
                return;
            }
            
            // Mostrar loading
            btn.disabled = true;
            btn.innerHTML = '<span class="loading-spinner"></span> Verificando...';
            
            try {
                // Consultar Firebase para verificar código
                const codeRef = database.ref('activationCodesFinancas/' + code);
                const snapshot = await codeRef.once('value');
                const codeData = snapshot.val();
                
                if (!codeData) {
                    errorDiv.textContent = 'Código não encontrado';
                    errorDiv.style.display = 'block';
                    btn.disabled = false;
                    btn.innerHTML = '<span>ATIVAR SISTEMA</span>';
                    return;
                }
                
                if (codeData.used === true) {
                    errorDiv.textContent = 'Código já foi utilizado';
                    errorDiv.style.display = 'block';
                    btn.disabled = false;
                    btn.innerHTML = '<span>ATIVAR SISTEMA</span>';
                    return;
                }
                
                // Código válido - marcar como usado e salvar dados
                const timestamp = Math.floor(Date.now() / 1000);
                
                await codeRef.update({
                    used: true,
                    activatedAt: timestamp,
                    userData: {
                        name: name,
                        email: email,
                        cpf: cpf,
                        whatsapp: whatsapp
                    }
                });
                
                // Salvar localmente
                localStorage.setItem('systemActivated', 'true');
                localStorage.setItem('userActivationCode', code);
                localStorage.setItem('userActivationData', JSON.stringify({
                    name, email, cpf, whatsapp
                }));
                isActivated = true;
                
                successDiv.textContent = '✅ Sistema ativado com sucesso! Redirecionando...';
                successDiv.style.display = 'block';
                
                setTimeout(() => {
                    showAuthScreen();
                }, 2000);
                
            } catch (error) {
                console.error('Erro na ativação:', error);
                errorDiv.textContent = 'Erro ao verificar código. Tente novamente.';
                errorDiv.style.display = 'block';
                btn.disabled = false;
                btn.innerHTML = '<span>ATIVAR SISTEMA</span>';
            }
        }

        // ============================================
        // AUTH FUNCTIONS
        // ============================================
        function showAuthScreen() {
            document.getElementById('activationScreen').style.display = 'none';
            document.getElementById('authScreen').style.display = 'flex';
            document.getElementById('mainApp').style.display = 'none';
        }

        function showMainApp() {
            document.getElementById('activationScreen').style.display = 'none';
            document.getElementById('authScreen').style.display = 'none';
            document.getElementById('mainApp').style.display = 'block';
        }

        function switchAuthTab(tab) {
            document.querySelectorAll('.auth-tab').forEach(t => t.classList.remove('active'));
            event.target.classList.add('active');
            
            if (tab === 'login') {
                document.getElementById('loginForm').style.display = 'block';
                document.getElementById('registerForm').style.display = 'none';
            } else {
                document.getElementById('loginForm').style.display = 'none';
                document.getElementById('registerForm').style.display = 'block';
            }
        }

        function login() {
            const email = document.getElementById('loginEmail').value;
            const password = document.getElementById('loginPassword').value;
            
            if (!email || !password) {
                alert('Preencha todos os campos');
                return;
            }

            if (isOnline && auth) {
                auth.signInWithEmailAndPassword(email, password)
                    .catch(error => alert('Erro: ' + error.message));
            } else {
                currentUser = { uid: 'offline', email: email, displayName: 'Usuário' };
                showMainApp();
                loadTransactions();
            }
        }

        function register() {
            const name = document.getElementById('registerName').value;
            const email = document.getElementById('registerEmail').value;
            const password = document.getElementById('registerPassword').value;
            
            if (!name || !email || !password) {
                alert('Preencha todos os campos');
                return;
            }

            if (isOnline && auth) {
                auth.createUserWithEmailAndPassword(email, password)
                    .then(cred => {
                        return cred.user.updateProfile({ displayName: name });
                    })
                    .catch(error => alert('Erro: ' + error.message));
            } else {
                currentUser = { uid: 'offline', email: email, displayName: name };
                showMainApp();
            }
        }

        function loginWithGoogle() {
            if (isOnline && auth) {
                const provider = new firebase.auth.GoogleAuthProvider();
                auth.signInWithPopup(provider)
                    .catch(error => alert('Erro: ' + error.message));
            } else {
                alert('Modo offline - login Google não disponível');
            }
        }

        function logout() {
            if (isOnline && auth) {
                auth.signOut();
            } else {
                currentUser = null;
                showAuthScreen();
            }
        }

        // ============================================
        // DATA FUNCTIONS
        // ============================================
        function loadUserData() {
            if (!currentUser || !isOnline) return;
            
            const userRef = database.ref('users/' + currentUser.uid);
            userRef.once('value').then(snapshot => {
                const data = snapshot.val();
                if (data) {
                    transactions = data.transactions || transactions;
                    customCategories = data.customCategories || customCategories;
                    saveLocalData();
                    loadTransactions();
                    renderCategories();
                }
            });
        }

        function syncData() {
            if (!currentUser || !isOnline) {
                showNotification('Modo offline - dados salvos localmente');
                return;
            }
            
            showSyncIndicator(true);
            
            const userRef = database.ref('users/' + currentUser.uid);
            userRef.set({
                transactions: transactions,
                customCategories: customCategories,
                lastSync: Date.now()
            }).then(() => {
                showSyncIndicator(false);
                showNotification('Sincronizado com sucesso!');
            }).catch(error => {
                showSyncIndicator(false);
                alert('Erro na sincronização: ' + error.message);
            });
        }

        function saveLocalData() {
            localStorage.setItem('transactions', JSON.stringify(transactions));
            localStorage.setItem('customCategories', JSON.stringify(customCategories));
        }

        function showSyncIndicator(syncing) {
            const indicator = document.getElementById('syncIndicator');
            if (syncing) {
                indicator.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Sincronizando...';
                indicator.style.background = 'var(--warning)';
            } else {
                indicator.innerHTML = '<i class="fas fa-check-circle"></i> Sincronizado';
                indicator.style.background = 'var(--success)';
            }
            indicator.classList.add('show');
            setTimeout(() => indicator.classList.remove('show'), 3000);
        }

        // ============================================
        // MONTH NAVIGATION
        // ============================================
        function changeMonth(direction) {
            currentDate.setMonth(currentDate.getMonth() + direction);
            updateMonthDisplay();
            loadTransactions();
        }

        function updateMonthDisplay() {
            const months = ['Janeiro', 'Fevereiro', 'Março', 'Abril', 'Maio', 'Junho', 
                          'Julho', 'Agosto', 'Setembro', 'Outubro', 'Novembro', 'Dezembro'];
            document.getElementById('currentMonth').textContent = 
                months[currentDate.getMonth()] + ' ' + currentDate.getFullYear();
        }

        // ============================================
        // SECTION NAVIGATION
        // ============================================
        function showSection(section) {
            document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
            document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
            
            document.getElementById(section + 'Section').classList.add('active');
            
            const navItems = document.querySelectorAll('.nav-item');
            const sectionMap = ['dashboard', 'allTransactions', 'categories', 'reports'];
            const index = sectionMap.indexOf(section);
            if (index >= 0) navItems[index].classList.add('active');
            
            if (section === 'reports') {
                setTimeout(updateCharts, 100);
            } else if (section === 'categories') {
                renderCategories();
            }
        }

        // ============================================
        // MODAL FUNCTIONS
        // ============================================
        function openModal(type) {
            currentType = type;
            document.getElementById('transactionModal').classList.add('active');
            selectType(type);
        }

        function closeModal() {
            document.getElementById('transactionModal').classList.remove('active');
            document.querySelector('form').reset();
            document.getElementById('date').valueAsDate = new Date();
        }

        function selectType(type) {
            currentType = type;
            document.querySelectorAll('.type-option').forEach(opt => opt.classList.remove('selected'));
            document.querySelector('.type-option.' + type).classList.add('selected');
            updateCategorySelect();
        }

        function updateCategorySelect() {
            const select = document.getElementById('category');
            select.innerHTML = '<option value="">Selecione...</option>';
            
            // Categorias padrão
            const defaults = defaultCategories[currentType];
            Object.keys(defaults).forEach(cat => {
                select.innerHTML += `<option value="${cat}">${cat}</option>`;
            });
            
            // Categorias customizadas
            customCategories.filter(c => c.type === currentType).forEach(cat => {
                select.innerHTML += `<option value="${cat.name}">${cat.name}</option>`;
            });
        }

        // ============================================
        // CURRENCY FORMAT
        // ============================================
        function formatCurrency(input) {
            let value = input.value.replace(/\D/g, '');
            value = (parseInt(value || 0) / 100).toFixed(2);
            input.value = 'R$ ' + value.replace('.', ',').replace(/(\d)(?=(\d{3})+(?!\d))/g, '$1.');
        }

        function parseCurrency(value) {
            return parseFloat(value.replace(/[R$ \.]/g, '').replace(',', '.')) || 0;
        }

        function formatMoney(value) {
            return 'R$ ' + value.toFixed(2).replace('.', ',').replace(/(\d)(?=(\d{3})+(?!\d))/g, '$1.');
        }

        // ============================================
        // SAVE TRANSACTION
        // ============================================
        function saveTransaction(event) {
            event.preventDefault();
            
            const category = document.getElementById('category').value;
            const amount = parseCurrency(document.getElementById('amount').value);
            
            if (!category || amount <= 0) {
                alert('Selecione uma categoria e informe um valor válido');
                return;
            }
            
            const transaction = {
                id: Date.now(),
                type: currentType,
                amount: amount,
                date: document.getElementById('date').value,
                category: category,
                description: document.getElementById('description').value || category,
                month: currentDate.getMonth(),
                year: currentDate.getFullYear()
            };
            
            transactions.push(transaction);
            saveLocalData();
            
            closeModal();
            loadTransactions();
            showNotification('Lançamento salvo!');
            
            if (isOnline && currentUser) {
                setTimeout(syncData, 1000);
            }
        }

        // ============================================
        // LOAD AND DISPLAY
        // ============================================
        function loadTransactions() {
            let monthTransactions = transactions.filter(t => 
                t.month === currentDate.getMonth() && t.year === currentDate.getFullYear()
            );
            
            const income = monthTransactions.filter(t => t.type === 'income').reduce((sum, t) => sum + t.amount, 0);
            const expense = monthTransactions.filter(t => t.type === 'expense').reduce((sum, t) => sum + t.amount, 0);
            const balance = income - expense;
            
            document.getElementById('totalIncome').textContent = formatMoney(income);
            document.getElementById('totalExpense').textContent = formatMoney(expense);
            document.getElementById('totalBalance').textContent = formatMoney(balance);
            document.getElementById('totalBalance').className = 'card-value ' + (balance >= 0 ? 'positive' : 'negative');
            
            updateAlert(income, expense);
            displayTransactions(monthTransactions.slice(-5).reverse(), 'recentTransactions');
            displayTransactions(transactions.slice().reverse(), 'allTransactions');
        }

        function updateAlert(income, expense) {
            const alertBox = document.getElementById('alertBox');
            const alertTitle = document.getElementById('alertTitle');
            const alertText = document.getElementById('alertText');
            
            if (income === 0) {
                alertBox.className = 'alert-box warning';
                alertTitle.textContent = '⚠️ Comece a registrar!';
                alertText.textContent = 'Adicione suas entradas para acompanhar';
            } else {
                const percent = (expense / income) * 100;
                const remaining = income - expense;
                
                if (percent >= 100) {
                    alertBox.className = 'alert-box danger';
                    alertTitle.textContent = '🚨 Estourou!';
                    alertText.textContent = 'Você gastou mais do que recebeu';
                } else if (percent >= 90) {
                    alertBox.className = 'alert-box warning';
                    alertTitle.textContent = '⚠️ Atenção!';
                    alertText.textContent = 'Gastou ' + percent.toFixed(0) + '%. Restam ' + formatMoney(remaining);
                } else if (percent >= 80) {
                    alertBox.className = 'alert-box warning';
                    alertTitle.textContent = '💡 Economize!';
                    alertText.textContent = 'Gastou ' + percent.toFixed(0) + '%. Meta: economizar 20%';
                } else {
                    alertBox.className = 'alert-box success';
                    alertTitle.textContent = '✅ Muito bem!';
                    alertText.textContent = 'Economia de ' + formatMoney(remaining);
                }
            }
        }

        function getCategoryColor(categoryName) {
            const defaults = { ...defaultCategories.income, ...defaultCategories.expense };
            if (defaults[categoryName]) return defaults[categoryName];
            
            const custom = customCategories.find(c => c.name === categoryName);
            if (custom) return custom.color;
            
            return '#6b7280';
        }

        function displayTransactions(list, containerId) {
            const container = document.getElementById(containerId);
            
            if (list.length === 0) {
                container.innerHTML = '<div class="empty-state"><i class="fas fa-receipt"></i><p>Nenhum lançamento</p></div>';
                return;
            }
            
            container.innerHTML = list.map(t => {
                const color = getCategoryColor(t.category);
                return `<div class="transaction-item" onclick="deleteTransaction(${t.id})">
                    <div class="transaction-icon ${t.type}">
                        <i class="fas fa-${t.type === 'income' ? 'arrow-down' : 'arrow-up'}"></i>
                    </div>
                    <div class="transaction-info">
                        <div class="transaction-title">${t.description}</div>
                        <div class="transaction-category">
                            <span class="category-dot" style="background: ${color}"></span>
                            ${t.category}
                        </div>
                    </div>
                    <div>
                        <div class="transaction-amount ${t.type}">
                            ${t.type === 'income' ? '+' : '-'} ${formatMoney(t.amount)}
                        </div>
                        <div style="font-size: 11px; color: var(--gray); text-align: right;">
                            ${formatDate(t.date)}
                        </div>
                    </div>
                </div>`;
            }).join('');
        }

        function formatDate(dateString) {
            const date = new Date(dateString + 'T00:00:00');
            return date.toLocaleDateString('pt-BR');
        }

        function deleteTransaction(id) {
            if (confirm('Deseja excluir este lançamento?')) {
                const index = transactions.findIndex(t => t.id === id);
                if (index > -1) {
                    transactions.splice(index, 1);
                    saveLocalData();
                    loadTransactions();
                    if (isOnline && currentUser) syncData();
                }
            }
        }

        // ============================================
        // CATEGORIES MANAGEMENT
        // ============================================
        function renderCategories() {
            const container = document.getElementById('categoryList');
            const allCategories = [
                ...Object.keys(defaultCategories.expense).map(name => ({ name, color: defaultCategories.expense[name], isDefault: true })),
                ...Object.keys(defaultCategories.income).map(name => ({ name, color: defaultCategories.income[name], isDefault: true })),
                ...customCategories.map(c => ({ ...c, isDefault: false }))
            ];
            
            container.innerHTML = allCategories.map(cat => `
                <div class="category-item">
                    <span class="category-dot" style="background: ${cat.color}"></span>
                    <span>${cat.name}</span>
                    ${!cat.isDefault ? `<i class="fas fa-trash" style="margin-left: auto; cursor: pointer; color: var(--danger);" onclick="deleteCategory('${cat.name}')"></i>` : ''}
                </div>
            `).join('');
        }

        function initColorPicker() {
            const picker = document.getElementById('colorPicker');
            picker.innerHTML = availableColors.map(color => `
                <div class="color-option ${color === selectedColor ? 'selected' : ''}" 
                     style="background: ${color}" 
                     onclick="selectColor('${color}')">
                </div>
            `).join('');
        }

        function selectColor(color) {
            selectedColor = color;
            document.querySelectorAll('.color-option').forEach(el => el.classList.remove('selected'));
            event.target.classList.add('selected');
        }

        function openCategoryModal() {
            document.getElementById('categoryModal').classList.add('active');
        }

        function closeCategoryModal() {
            document.getElementById('categoryModal').classList.remove('active');
            document.getElementById('newCategoryName').value = '';
        }

        function saveCategory(event) {
            event.preventDefault();
            
            const name = document.getElementById('newCategoryName').value.trim();
            
            if (!name) {
                alert('Digite um nome para a categoria');
                return;
            }
            
            const allNames = [
                ...Object.keys(defaultCategories.income),
                ...Object.keys(defaultCategories.expense),
                ...customCategories.map(c => c.name)
            ];
            
            if (allNames.includes(name)) {
                alert('Esta categoria já existe');
                return;
            }
            
            customCategories.push({
                name: name,
                color: selectedColor,
                type: currentType
            });
            
            saveLocalData();
            renderCategories();
            closeCategoryModal();
            showNotification('Categoria criada!');
            
            if (isOnline && currentUser) syncData();
        }

        function deleteCategory(name) {
            if (confirm(`Deseja excluir a categoria "${name}"?`)) {
                customCategories = customCategories.filter(c => c.name !== name);
                saveLocalData();
                renderCategories();
                if (isOnline && currentUser) syncData();
            }
        }

        // ============================================
        // CHARTS
        // ============================================
        function updateCharts() {
            const monthTransactions = transactions.filter(t => 
                t.month === currentDate.getMonth() && t.year === currentDate.getFullYear()
            );
            
            const expensesByCategory = {};
            monthTransactions.filter(t => t.type === 'expense').forEach(t => {
                expensesByCategory[t.category] = (expensesByCategory[t.category] || 0) + t.amount;
            });
            
            if (window.expenseChartInstance) {
                window.expenseChartInstance.destroy();
            }
            
            const ctx1 = document.getElementById('expenseChart').getContext('2d');
            window.expenseChartInstance = new Chart(ctx1, {
                type: 'doughnut',
                data: {
                    labels: Object.keys(expensesByCategory),
                    datasets: [{
                        data: Object.values(expensesByCategory),
                        backgroundColor: Object.keys(expensesByCategory).map(cat => getCategoryColor(cat)),
                        borderWidth: 2,
                        borderColor: '#fff'
                    }]
                },
                options: {
                    responsive: true,
                    maintainAspectRatio: false,
                    plugins: {
                        legend: { 
                            position: 'right', 
                            labels: { 
                                boxWidth: 12, 
                                font: { size: 11 },
                                color: '#1a237e'
                            } 
                        }
                    },
                    cutout: '60%'
                }
            });
        }

        // ============================================
        // PDF GENERATION
        // ============================================
        function generatePDF() {
            const { jsPDF } = window.jspdf;
            const doc = new jsPDF();
            
            const monthTransactions = transactions.filter(t => 
                t.month === currentDate.getMonth() && t.year === currentDate.getFullYear()
            );
            
            const income = monthTransactions.filter(t => t.type === 'income').reduce((sum, t) => sum + t.amount, 0);
            const expense = monthTransactions.filter(t => t.type === 'expense').reduce((sum, t) => sum + t.amount, 0);
            
            // Header
            doc.setFillColor(26, 35, 126);
            doc.rect(0, 0, 210, 50, 'F');
            
            doc.setTextColor(212, 175, 55);
            doc.setFontSize(28);
            doc.text('Minhas Finanças PRO', 105, 30, { align: 'center' });
            
            doc.setTextColor(255, 255, 255);
            doc.setFontSize(12);
            doc.text('ASM Gestão Financeira', 105, 42, { align: 'center' });
            
            // Mês
            doc.setTextColor(26, 35, 126);
            doc.setFontSize(16);
            doc.text(document.getElementById('currentMonth').textContent, 20, 70);
            
            // Resumo
            doc.setFontSize(14);
            doc.text('RESUMO DO MÊS', 20, 85);
            
            doc.setFontSize(12);
            doc.setTextColor(76, 175, 80);
            doc.text(`Entradas: ${formatMoney(income)}`, 20, 100);
            doc.setTextColor(244, 67, 54);
            doc.text(`Saídas: ${formatMoney(expense)}`, 20, 115);
            doc.setTextColor(26, 35, 126);
            doc.setFontSize(14);
            doc.text(`Saldo: ${formatMoney(income - expense)}`, 20, 135);
            
            // Lançamentos
            let y = 160;
            doc.setFontSize(12);
            doc.setTextColor(26, 35, 126);
            doc.text('LANÇAMENTOS:', 20, y);
            y += 15;
            
            monthTransactions.slice().reverse().forEach(t => {
                if (y > 270) {
                    doc.addPage();
                    y = 20;
                }
                doc.setFontSize(10);
                doc.setTextColor(100);
                doc.text(`${formatDate(t.date)} - ${t.category}`, 20, y);
                doc.setTextColor(t.type === 'income' ? 76 : 244, t.type === 'income' ? 175 : 67, t.type === 'income' ? 80 : 54);
                doc.text(`${t.type === 'income' ? '+' : '-'} ${formatMoney(t.amount)}`, 180, y, { align: 'right' });
                y += 10;
            });
            
            doc.save(`Financas_${currentDate.getMonth()}_${currentDate.getFullYear()}.pdf`);
            showNotification('PDF gerado!');
        }

        function showNotification(message) {
            const notif = document.createElement('div');
            notif.style.cssText = 'position: fixed; top: 20px; left: 50%; transform: translateX(-50%); background: var(--navy); color: var(--gold); padding: 15px 30px; border-radius: 12px; font-weight: 600; z-index: 3000; box-shadow: 0 4px 15px rgba(0,0,0,0.3);';
            notif.textContent = message;
            document.body.appendChild(notif);
            setTimeout(() => notif.remove(), 3000);
        }

        // Close modals on outside click
        document.querySelectorAll('.modal').forEach(modal => {
            modal.addEventListener('click', function(e) {
                if (e.target === this) {
                    this.classList.remove('active');
                }
            });
        });
    </script>
</body>
</html>
